{
  "name": "hitfactorinfo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": "20.x.x"
  },
  "scripts": {
    "========================= Development ====================": "",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "tsx --test",
    "lint": "eslint ./",
    "========================= PayloadCMS ====================": "",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "========================= Production ====================": "",
    "prod": "npm run build && npm run start",
    "========================== Upload Scripts (Render.com Worker/CRON) ========================": "",
    "uploadMatches": "cross-env NODE_OPTIONS=--max-old-space-size=2048 node --env-file=.env --import=tsx scripts/upload/matchesLoop.ts",
    "uploadScores": "cross-env NODE_OPTIONS=--max-old-space-size=2048 node --env-file=.env --import=tsx scripts/upload/scoresLoop.ts",
    "uploadMeta": "cross-env NODE_OPTIONS=--max-old-space-size=2048 node --env-file=.env --import=tsx scripts/upload/statsMetaLoop.ts",
    "uploadMembers": "cross-env NODE_OPTIONS=--max-old-space-size=2048 node --env-file=.env --import=tsx scripts/upload/activeMembers.ts",
    "========================= DB Admin Scripts ============================": "",
    "hydrate": "cross-env NODE_OPTIONS=--max-old-space-size=4096 node --env-file=.env --import=tsx scripts/migrations/rehydrateForCC.ts",
    "uspsa": "cross-env NODE_OPTIONS=--max-old-space-size=16384 node --env-file=.env --import=tsx scripts/experiments/hydrateFromUSPSAJSON.ts",
    "dumpprod": "mongodump --uri=%MONGO_URL_PROD%",
    "dumplocal": "mongodump --uri=%MONGO_URL_LOCAL%",
    "restoreprod": "mongorestore --drop --uri=%MONGO_URL_PROD% dump/theta",
    "restorelocal": "mongorestore --drop --uri=%MONGO_URL_LOCAL% dump/theta"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.51.15",
    "@types/lodash": "^4.17.9",
    "@types/node": "^22.7.4",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "bson": "^6.10.3",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.5",
    "prettier": "^3.3.3",
    "sass": "^1.97.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "zenrows": "^1.3.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@payloadcms/db-mongodb": "^3.75.0",
    "@payloadcms/next": "^3.75.0",
    "@payloadcms/richtext-lexical": "^3.75.0",
    "@tanstack/react-query": "^5.51.15",
    "algoliasearch": "^5.48.0",
    "chart.js": "^4.4.3",
    "graphql": "^16.12.0",
    "lodash.sorteduniqby": "^4.7.0",
    "lodash.throttle": "^4.1.1",
    "lodash.transform": "^4.6.0",
    "lodash.uniqby": "^4.7.0",
    "next": "^16.1.6",
    "payload": "^3.75.0",
    "piscina": "^5.0.0-alpha.0",
    "playwright": "^1.58.2",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primereact": "^10.8.2",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.2.4",
    "react-minimal-pie-chart": "^8.4.0",
    "react-multi-progress": "^1.0.3",
    "react-player": "^2.16.0",
    "sharp": "^0.34.5",
    "simple-statistics": "^7.8.7",
    "undici": "^6.18.2",
    "use-debounce": "^10.0.0",
    "uuid": "^9.0.1"
  }
}
