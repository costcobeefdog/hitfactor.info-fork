# ==============================================
# HitFactor.Info Environment Variables
# ==============================================
# Copy this file to .env and fill in your values

# ==============================================
# Required - Database
# ==============================================

# MongoDB connection string
MONGO_URL=mongodb://localhost:27017/hitfactor

# ==============================================
# Required - PayloadCMS
# ==============================================

# Secret key for PayloadCMS (use a random 32+ character string in production)
PAYLOAD_SECRET=your-secret-key-change-in-production

# ==============================================
# Optional - Upload Scripts
# ==============================================

# Algolia credentials for match discovery
ALGOLIA_APP_ID=
ALGOLIA_URL=

# PractiScore S3 credentials for fetching match data
PS_S3_ACCESS_KEY_ID=
PS_S3_SECRET_ACCESS_KEY=

# Allow marking scores as bad (admin feature)
ALLOW_MARK_BAD=

# ==============================================
# Optional - Development
# ==============================================

# Enable local development mode (1 to enable)
LOCAL_DEV=

# Production MongoDB URL (for dump/restore scripts)
MONGO_URL_PROD=

# Local MongoDB URL (for dump/restore scripts)
MONGO_URL_LOCAL=mongodb://localhost:27017/hitfactor
